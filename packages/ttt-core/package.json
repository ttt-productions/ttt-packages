{
    "name": "@ttt-productions/ttt-core",
    "version": "0.14.7",
    "description": "Core types, Firestore path constants, and shared constants for TTT Productions",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ttt-productions/ttt-packages.git",
        "directory": "packages/ttt-core"
    },
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        },
        "./paths": {
            "types": "./dist/paths/index.d.ts",
            "default": "./dist/paths/index.js"
        },
        "./constants": {
            "types": "./dist/constants/index.d.ts",
            "default": "./dist/constants/index.js"
        },
        "./constants/business": {
            "types": "./dist/constants/business.d.ts",
            "default": "./dist/constants/business.js"
        },
        "./constants/moderation": {
            "types": "./dist/constants/moderation.d.ts",
            "default": "./dist/constants/moderation.js"
        },
        "./constants/options": {
            "types": "./dist/constants/options.d.ts",
            "default": "./dist/constants/options.js"
        },
        "./constants/pagination": {
            "types": "./dist/constants/pagination.d.ts",
            "default": "./dist/constants/pagination.js"
        },
        "./constants/retention": {
            "types": "./dist/constants/retention.d.ts",
            "default": "./dist/constants/retention.js"
        },
        "./constants/scheduled-jobs": {
            "types": "./dist/constants/scheduled-jobs.d.ts",
            "default": "./dist/constants/scheduled-jobs.js"
        },
        "./constants/storage-keys": {
            "types": "./dist/constants/storage-keys.d.ts",
            "default": "./dist/constants/storage-keys.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "default": "./dist/utils/index.js"
        },
        "./schemas": {
            "types": "./dist/schemas/index.d.ts",
            "default": "./dist/schemas/index.js"
        },
        "./schemas/notification": {
            "types": "./dist/schemas/notification.d.ts",
            "default": "./dist/schemas/notification.js"
        },
        "./doc-schemas": {
            "types": "./dist/doc-schemas/index.d.ts",
            "default": "./dist/doc-schemas/index.js"
        },
        "./upload-variables": {
            "types": "./dist/upload-variables/index.d.ts",
            "default": "./dist/upload-variables/index.js"
        },
        "./media": {
            "types": "./dist/media/index.d.ts",
            "default": "./dist/media/index.js"
        },
        "./permissions": {
            "types": "./dist/permissions/index.d.ts",
            "default": "./dist/permissions/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist *.tsbuildinfo",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run clean && npm run build",
        "test": "vitest run"
    },
    "dependencies": {
        "@ttt-productions/audit-core": "*",
        "@ttt-productions/chat-schemas": "*",
        "@ttt-productions/edge-protocol-core": "*",
        "@ttt-productions/media-schemas": "*",
        "@ttt-productions/report-core": "*",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "typescript": "^5.8.3"
    },
    "author": "DJ (TTT Productions)",
    "license": "MIT"
}
