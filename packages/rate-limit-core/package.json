{
    "name": "@ttt-productions/rate-limit-core",
    "version": "0.3.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ttt-productions/ttt-packages.git",
        "directory": "packages/rate-limit-core"
    },
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
