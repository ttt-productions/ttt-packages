{
    "name": "@ttt-productions/upload-ui",
    "version": "0.3.3",
    "description": "Upload UI primitives: local upload guard provider, useGuardedUpload helper, DeferredUploadFormShell for forms that defer Firebase Storage upload until form submit.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ttt-productions/ttt-packages.git",
        "directory": "packages/upload-ui"
    },
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./react/guard": {
            "types": "./dist/react/guard/index.d.ts",
            "default": "./dist/react/guard/index.js"
        },
        "./react/upload": {
            "types": "./dist/react/upload/index.d.ts",
            "default": "./dist/react/upload/index.js"
        },
        "./react/tray": {
            "types": "./dist/react/tray/index.d.ts",
            "default": "./dist/react/tray/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist *.tsbuildinfo",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "dependencies": {
        "@ttt-productions/file-input": "*",
        "@ttt-productions/media-schemas": "*",
        "@ttt-productions/ui-core": "*",
        "@ttt-productions/upload-core": "*"
    },
    "peerDependencies": {
        "@tanstack/react-query": ">=5.0.0",
        "firebase": ">=10.0.0",
        "lucide-react": ">=0.300.0",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "@tanstack/react-query": {
            "optional": true
        },
        "firebase": {
            "optional": true
        },
        "lucide-react": {
            "optional": true
        },
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "typescript": "^5.8.3"
    },
    "author": "DJ (TTT Productions)",
    "license": "MIT"
}
